# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Database (from Supabase dashboard -> Settings -> Database) ===
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543)
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use the "Session" pooler or direct URL for DIRECT_URL (port 5432)
DIRECT_URL=postgresql://postgres.xxxxx:password@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# === AI Provider ===
# OpenAI is the default. Use AI_PROVIDER=gpt-sw3 for Swedish/Nordic matching via Hugging Face.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
HUGGINGFACE_API_TOKEN=
GPT_SW3_MODEL=AI-Sweden-Models/gpt-sw3-6.7b-v2-instruct
# Optional if you deploy GPT-SW3 behind a dedicated Hugging Face Inference Endpoint.
# GPT_SW3_ENDPOINT=https://your-endpoint.huggingface.cloud
ANTHROPIC_API_KEY=

# === App ===
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Stripe (optional, for future payments) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
